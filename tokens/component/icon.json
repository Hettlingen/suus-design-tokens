{
  "icon": {
    "size": {
      "small": { "$value": "16px", "$type": "dimension" },
      "medium": { "$value": "24px", "$type": "dimension" },
      "large": { "$value": "32px", "$type": "dimension" }
    },
    "color": {
      "default": { "$value": "{color.text.dark}", "$type": "color" },
      "glassy": { "$value": "{color.text.light}", "$type": "color" },
      "text": { "$value": "{color.text.dark}", "$type": "color" },
      "text-glassy": { "$value": "{color.text.light}", "$type": "color" }
    }
  }
}
