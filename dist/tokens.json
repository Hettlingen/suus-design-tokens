{
  "button": {
    "border-width": "1px",
    "padding": "12px",
    "radius": "100vw"
  },
  "icon": {
    "size": {
      "small": "16px",
      "medium": "24px",
      "large": "32px"
    },
    "color": {
      "default": "#272727",
      "glassy": "#ffffff",
      "text": "#272727",
      "text-glassy": "#ffffff"
    }
  },
  "input": {
    "border-width": "1px",
    "padding": "16px",
    "radius": "8px",
    "background-color": "#ffffff",
    "text-color": "#272727",
    "font-size": "16px"
  },
  "panel": {
    "background-color": "#e1e0df",
    "padding": {
      "desktop": "32px",
      "mobile": "16px"
    }
  },
  "tile": {
    "background-color": {
      "left-top": "#ffffff",
      "right-bottom": "#ffffff"
    },
    "border-color": {
      "left-top": "#cecece",
      "right-bottom": "#cecece"
    },
    "border-radius": {
      "small": "12px",
      "large": "24px",
      "huge": "100vw"
    },
    "shadow": "0 4px 6px rgba(0, 0, 0, 0.1), 0 1px 3px rgba(0, 0, 0, 0.06)",
    "padding": "16px"
  },
  "border": {
    "width": {
      "thin": "0.5px",
      "default": "1px",
      "thick": "2px"
    }
  },
  "color": {
    "brand": {
      "primary": {
        "midnight": "#5c6814",
        "dark": "#8fa02a",
        "default": "#afc33b",
        "light": "#d1da96",
        "bright": "#e7f880"
      },
      "secondary": {
        "midnight": "#97771d",
        "dark": "#b58f24",
        "default": "#d9ab29",
        "light": "#eec348",
        "bright": "#f9db86"
      },
      "black": "#272727",
      "dark-gray": "#5b5a5a",
      "gray": "#c2bfbf",
      "light-gray": "#e1e0df",
      "white": "#ffffff",
      "light": "#d6e66c"
    },
    "product": {
      "sugarcane": "#a7b325",
      "tamarind": "#f8a702",
      "guava": "#7441aa",
      "icetea": "#e14a4a"
    },
    "status": {
      "success": "#99af17",
      "info": "#6a7a0a",
      "warning": "#f9db86",
      "error": "#ea720e"
    },
    "text": {
      "dark": "#272727",
      "light": "#ffffff",
      "colored": "#6a7a0a"
    },
    "disabled": "#cecece",
    "border": {
      "default": "#cecece",
      "left-top": "#cecece",
      "right-bottom": "#b5b5b5"
    },
    "link": "#99af17",
    "hover": {
      "default": "#bcca63",
      "inverse": "#f3f4f0"
    }
  },
  "radius": {
    "small": "8px",
    "default": "16px",
    "large": "24px",
    "round": "100vw"
  },
  "shadow": {
    "card": "0 18px 45px rgba(15, 23, 42, 0.12)"
  },
  "spacing": {
    "tiny": "8px",
    "small": "16px",
    "default": "24px",
    "large": "32px",
    "huge": "40px",
    "very-huge": "60px"
  },
  "breakpoint": {
    "smartphone": "480px",
    "tablet": "768px",
    "desktop": "1200px",
    "desktop-wide": "1600px"
  },
  "font": {
    "family": {
      "sans-serif": "OpenSans",
      "serif": "Baskerville"
    },
    "size": {
      "tiny": "14px",
      "small": "16px",
      "standard": "20px",
      "large": "24px",
      "title": "2rem",
      "subtitle": "1.3rem"
    },
    "style": {
      "normal": "normal",
      "italic": "italic"
    },
    "weight": {
      "light": 300,
      "normal": 400,
      "bold": 700
    },
    "letter-spacing": {
      "default": "0.016rem"
    }
  }
}
